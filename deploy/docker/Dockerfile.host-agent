FROM rust:1.83-alpine AS builder

RUN apk add --no-cache musl-dev protobuf-dev

WORKDIR /app

COPY proto/ proto/
COPY runtime/ runtime/

WORKDIR /app/runtime
RUN cargo build --release --bin host-agent

FROM alpine:3.20

RUN apk --no-cache add ca-certificates
COPY --from=builder /app/runtime/target/release/host-agent /host-agent

ENTRYPOINT ["/host-agent"]
